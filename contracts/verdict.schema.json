{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kitsune.dev/contracts/verdict.schema.json",
  "title": "Verdict",
  "description": "The scored result for a session. Every point of bot-likelihood traces back to evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "session_id", "layer_scores", "contradictions",
    "incoherence_score", "score", "label", "ruleset_version", "scored_at"
  ],
  "$defs": {
    "unit_interval": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "layers", "detail", "weight", "evidence"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "layers": {
          "type": "array",
          "items": { "type": "string", "enum": ["network", "browser", "behavioral", "reputation"] },
          "minItems": 1
        },
        "detail": { "type": "string" },
        "weight": { "$ref": "#/$defs/unit_interval" },
        "evidence": {
          "type": "array",
          "description": "Signal references (layer.kind) that triggered this contradiction.",
          "items": { "type": "string" }
        }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "session_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "layer_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "browser", "behavioral", "reputation"],
      "properties": {
        "network": { "$ref": "#/$defs/unit_interval" },
        "browser": { "$ref": "#/$defs/unit_interval" },
        "behavioral": { "$ref": "#/$defs/unit_interval" },
        "reputation": { "$ref": "#/$defs/unit_interval" }
      }
    },
    "contradictions": { "type": "array", "items": { "$ref": "#/$defs/contradiction" } },
    "incoherence_score": { "$ref": "#/$defs/unit_interval" },
    "score": { "$ref": "#/$defs/unit_interval", "description": "Final bot-likelihood, 1 = bot." },
    "label": { "type": "string", "enum": ["human", "suspicious", "bot"] },
    "ruleset_version": { "type": "string" },
    "scored_at": { "type": "string", "format": "date-time" }
  }
}
